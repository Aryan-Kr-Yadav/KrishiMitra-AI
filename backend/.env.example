# Server
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed origins for CORS
FRONTEND_URL=http://localhost:5173

# Google Gemini API key — get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini models used. The 1.5 family is multimodal (handles both vision and
# text), so we use a fast model for image diagnosis and a stronger model for
# text reasoning. Swap these freely as Google releases newer models.
GEMINI_VISION_MODEL=gemini-1.5-flash
GEMINI_TEXT_MODEL=gemini-1.5-pro

# Max upload size in bytes (default 5MB)
MAX_UPLOAD_SIZE=5242880

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
